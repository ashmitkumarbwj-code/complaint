# Smart Campus Complaint & Response System - Environment Variables Example

# Server Configuration
PORT=3000
NODE_ENV=production
BASE_URL=https://yourdomain.com
# Comma-separated allowed CORS origins (optional; BASE_URL is also used)
# FRONTEND_URLS=http://localhost:3000,https://app.yourdomain.com

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=smart_campus_db
# DB_POOL_SIZE=10

# Redis (required for BullMQ queues: notifications, uploads)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# Security
JWT_SECRET=your_long_random_jwt_secret_here

# Cloudinary (Media Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Nodemailer - SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Twilio (SMS Notifications)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Firebase Admin SDK (optional - for verify-firebase login)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your_project_id",...}

# Logging (optional)
# LOG_LEVEL=info
